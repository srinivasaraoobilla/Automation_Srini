def find_biggest_number(num1, num2):
    """
    Returns the biggest number between two given numbers.
    """
    return max(num1, num2)

# Example usage:
if __name__ == "__main__":
    a = float(input("Enter first number: "))
    b = float(input("Enter second number: "))
    print(f"The biggest number is: {find_biggest_number(a, b)}")