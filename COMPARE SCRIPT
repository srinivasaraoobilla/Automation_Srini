function compare(a, b) {
  if (a > b) {
    return `${a} is greater than ${b}`;
  } else if (a < b) {
    return `${a} is less than ${b}`;
  } else {
    return `${a} is equal to ${b}`;
  }
}

// Example usage:
console.log(compare(10, 5));   // 10 is greater than 5
console.log(compare(3, 8));    // 3 is less than 8
console.log(compare(7, 7));    // 7 is equal to 7
